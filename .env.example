# ── Rakib Portfolio — environment variables ──────────────────────────────────
# Copy to .env.local for local dev, and set the same in the Vercel dashboard.
# NEVER commit real values. .env* is gitignored.

# ── Contact form (Resend) ────────────────────────────────────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY="re_Z5cPT6ip_LVq5VsaT4AyTJEnp6khJzVmA"

# Where contact-form submissions are delivered (defaults to naym.mj@gmail.com)
CONTACT_TO_EMAIL="naym.mj@gmail.com"
# Verified sender. Until you verify a domain in Resend, use their sandbox sender:
#   "Portfolio <onboarding@resend.dev>"
# After verifying your domain, use e.g. "Rakib <hello@yourdomain.com>"
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# ── AI chatbot (Google Vertex AI / Gemini) ───────────────────────────────────
# Base64 of your service_account.json (recommended for Vercel).
# Generate locally with:   base64 -w0 service_account.json   (Linux)
#                          base64 -i service_account.json    (macOS)
#                          [Convert]::ToBase64String([IO.File]::ReadAllBytes("service_account.json"))  (Windows PowerShell)
GOOGLE_SERVICE_ACCOUNT_B64=

# For LOCAL dev you may instead point at the JSON file directly (leave the B64 blank):
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

GCP_PROJECT_ID=calm-sylph-440605-q7
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# ── Public site URL (used for SEO/OG/sitemap) ────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://rakib-portfolio-lilac.vercel.app
